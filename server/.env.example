# Server
NODE_ENV=production
PORT=5000

# Database
DATABASE_URL=postgresql://username:password@host:5432/zapbill_db

# Security
JWT_SECRET=minimum-32-character-random-string-here
JWT_EXPIRES_IN=24h
LICENSE_ENCRYPTION_KEY=64-character-hex-string-here
HMAC_SECRET=another-32-character-random-string

# CORS
ALLOWED_ORIGINS=https://admin.zapbill.com,http://localhost:3000,http://localhost:5173

# Email (SMTP) - Optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@zapbill.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=ZapBill <noreply@zapbill.com>

# App
ADMIN_PANEL_URL=https://admin.zapbill.com
API_BASE_URL=https://api.zapbill.com
